---
import Layout from '../layouts/Layout.astro'
import PhoneMockup from '../components/PhoneMockup.tsx'
import LogoMark from '../components/LogoMark.astro'
import SiteFooter from '../components/SiteFooter.astro'

// SVG icons inlined for zero-dependency icons
const AppleSVG = `<svg width="18" height="22" viewBox="0 0 24 29" fill="currentColor" aria-hidden="true"><path d="M20.92 22.27c-.97 1.45-1.99 2.87-3.57 2.9-1.57.04-2.07-.93-3.85-.93-1.79 0-2.34.9-3.83.96-1.53.06-2.69-1.54-3.67-2.97C3.35 19.41 1.77 13.73 3.9 9.84c1.02-1.78 2.84-2.9 4.82-2.94 1.5-.02 2.92 1.01 3.85 1.01.91 0 2.64-1.25 4.45-1.07.76.04 2.88.31 4.25 2.32-.1.07-2.54 1.5-2.51 4.46.04 3.54 3.1 4.71 3.13 4.73-.03.07-.49 1.68-1.62 3.3zm-4.33-18.9c.85-.97 2.27-1.7 3.44-1.74.15 1.37-.4 2.75-1.22 3.73-.8 1-2.14 1.77-3.45 1.66-.18-1.34.48-2.75 1.23-3.65z"/></svg>`

const PlaySVG = `<svg width="18" height="20" viewBox="0 0 24 27" fill="currentColor" aria-hidden="true"><path d="M2.13 26.5c.38.21.84.23 1.26.02L18.98 18.1l-3.47-3.47L2.13 26.5zm-1.75-22.4v22.05c0 .52.3.97.71 1.19V2.91c-.41.22-.71.67-.71 1.19zM16.89 11.56l2.07-1.16.06-.04L5.63.31 3.39.02l13.5 11.54zM20.47 9.5l-1.51 2.06-6.23 5.85 6.23 5.85 1.51-.84c.96-.54.96-1.5 0-2.04L20.47 9.5z"/></svg>`

const CHROMATIC_NOTES = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B']

const STEPS = [
  {
    num: '01',
    title: 'Listen',
    body: 'A note plays from a real piano sample. Replay it as many times as you need. There is no time pressure.',
  },
  {
    num: '02',
    title: 'Identify',
    body: 'Tap the note name you heard. Instant visual and haptic feedback confirms your answer.',
  },
  {
    num: '03',
    title: 'Unlock',
    body: 'Hit 80% accuracy across 20 attempts to unlock the next module. Genuine mastery — not just repetition.',
  },
]

const FEATURES = [
  { label: 'Note recognition', desc: 'Hear a note. Name it.' },
  { label: 'Melodic dictation', desc: 'Sequences from 2 up to 5 notes' },
  { label: 'Interval training', desc: 'Fixed, multi-root, and random tonic' },
  { label: 'Chord recognition', desc: 'Hear harmony by scale degree in C major' },
  { label: 'Chord progressions', desc: 'Build 4-chord loops by ear, one degree at a time' },
]

const HARMONY_CHAPTERS = [
  {
    num: '04',
    title: 'Chords',
    subtitle: 'Hear harmony in C major',
    body:
      'Stay anchored in C major and learn what each chord feels like compared to home. You answer by scale degree, not by memorizing isolated chord names.',
    accent: 'var(--color-accent)',
    modules: [
      { title: 'The Big Three', detail: 'I • IV • V' },
      { title: 'The Darker Six', detail: 'Adds vi' },
      { title: 'The Soft Two', detail: 'Adds ii' },
      { title: 'The Dreamy Three', detail: 'Adds iii' },
      { title: 'The Unstable Seven', detail: 'Completes all 7 diatonic chords' },
    ],
  },
  {
    num: '05',
    title: 'Progressions',
    subtitle: 'Recognize chord patterns',
    body:
      'Once the chords are familiar, order becomes the lesson. The same four chords can feel bright, wistful, lifted, or unresolved depending on where the loop begins and how it moves.',
    accent: 'var(--color-accent-soft)',
    modules: [
      { title: 'The Classics', detail: 'I → IV → V → I' },
      { title: 'The Darker Start', detail: 'vi → IV → I → V' },
      { title: 'The Fifties', detail: 'I → vi → IV → V' },
      { title: 'More Patterns', detail: 'Alt Pop • Country Road • Anthem' },
      { title: 'The Full Mix', detail: 'Jazz Resolve • Andalusian • Minor Tension' },
    ],
  },
]

const PROGRESSION_PATTERNS = [
  { name: 'The Pop Loop', degrees: 'I → V → vi → IV', vibe: 'Bright, darker, lifted' },
  { name: 'Jazz Resolve', degrees: 'ii → V → I → I', vibe: 'Setup, tension, full landing' },
  { name: 'Minor Descent', degrees: 'vi → V → IV → I', vibe: 'Dark to resolved' },
]

const NOTE_ACCURACY = [
  { note: 'C',  pct: 84, mastered: true  },
  { note: 'E',  pct: 78, mastered: true  },
  { note: 'G',  pct: 81, mastered: true  },
  { note: 'D',  pct: 62, mastered: true  },
  { note: 'F',  pct: 71, mastered: true  },
  { note: 'A',  pct: 58, mastered: false },
  { note: 'B',  pct: 44, mastered: false },
  { note: 'C#', pct: 37, mastered: false },
  { note: 'D#', pct: 18, mastered: false },
  { note: 'F#', pct: 29, mastered: false },
  { note: 'G#', pct: 44, mastered: false },
  { note: 'A#', pct: 36, mastered: false },
]
---

<Layout
  description="Build reliable pitch recognition through progressive, focused practice. Start with three notes, master all twelve, then move into chords and chord progressions."
>
  <!-- ── NAV ──────────────────────────────────────────────── -->
  <nav
    class="fixed top-0 left-0 right-0 z-50"
    style="background: rgba(15,17,21,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(47,53,65,0.5);"
  >
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <LogoMark />
        <span style="color: var(--color-dark-text); font-weight: 600; letter-spacing: -0.02em;">Absolute Ear</span>
      </div>
      <a
        href="https://apps.apple.com/app/id6758640410"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5"
        style="text-decoration: none;"
        aria-label="Download Absolute Ear on the App Store"
      >
        <div
          aria-hidden="true"
          class="w-2 h-2 rounded-full"
          style="background: var(--color-dark-accent);"
        ></div>
        <span style="font-size: 13px; color: var(--color-dark-text-3); font-family: var(--font-mono);">Available on iOS</span>
      </a>
    </div>
  </nav>

  <main id="main-content">

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section
    class="min-h-[100dvh] flex items-center pt-16"
    style="background: var(--color-dark-bg);"
  >
    <div class="max-w-7xl mx-auto px-6 py-20 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] xl:grid-cols-[1fr_340px] gap-12 xl:gap-20 items-center">

        <!-- Left: Content -->
        <div>
          <!-- Tag line -->
          <div class="hero-enter flex items-center gap-3 mb-10">
            <div class="h-px w-8" style="background: var(--color-dark-accent);"></div>
            <span style="font-size: 11px; font-family: var(--font-mono); color: var(--color-dark-accent); text-transform: uppercase; letter-spacing: 0.2em;">
              iOS · Now Available · Android Coming Soon
            </span>
          </div>

          <!-- Headline -->
          <h1
            class="hero-enter hero-enter-d1 font-bold tracking-tight mb-7"
            style="font-size: clamp(3.5rem, 8vw, 7.5rem); line-height: 0.94; letter-spacing: -0.03em; color: var(--color-dark-text);"
          >
            Train your ears<br />
            to hear every<br />
            <span style="color: var(--color-dark-accent);">note.</span>
          </h1>

          <!-- Body -->
          <p
            class="hero-enter hero-enter-d2 leading-relaxed mb-10"
            style="font-size: 1.125rem; color: var(--color-dark-text-2); max-width: 46ch;"
          >
            Absolute Ear builds reliable pitch recognition through progressive, focused practice —
            starting from three notes, expanding to all twelve chromatic tones,
            then into chords and chord progressions.
          </p>

          <!-- Store buttons -->
          <div class="hero-enter hero-enter-d3 flex flex-wrap gap-4">
            <!-- App Store -->
            <a
              href="https://apps.apple.com/app/id6758640410"
              target="_blank"
              rel="noopener noreferrer"
              class="store-btn flex items-center gap-3 rounded-xl font-semibold hover:opacity-90 active:scale-[0.97]"
              style="padding: 12px 22px; background: var(--color-dark-text); color: var(--color-dark-bg);"
              aria-label="Download Absolute Ear on the App Store"
            >
              <Fragment set:html={AppleSVG} />
              <div>
                <div style="font-size:10px; font-weight:500; opacity:0.6; line-height:1; margin-bottom:2px;">
                  Download on the
                </div>
                <div style="font-size:15px; font-weight:700; line-height:1;">App Store</div>
              </div>
            </a>

            <!-- Google Play -->
            <div class="relative">
              <a
                href="#download"
                class="store-btn flex items-center gap-3 rounded-xl font-semibold hover:opacity-90 active:scale-[0.97]"
                style="padding: 12px 22px; border: 1px solid var(--color-dark-border); color: var(--color-dark-text); background: transparent;"
                aria-label="Get it on Google Play (coming soon)"
              >
                <Fragment set:html={PlaySVG} />
                <div>
                  <div style="font-size:10px; font-weight:500; opacity:0.6; line-height:1; margin-bottom:2px;">
                    Get it on
                  </div>
                  <div style="font-size:15px; font-weight:700; line-height:1;">Google Play</div>
                </div>
              </a>
              <span
                class="absolute -top-2 -right-2 font-mono font-bold rounded-full"
                style="font-size: 9px; background: var(--color-dark-accent); color: var(--color-dark-bg); padding: 2px 7px;"
              >
                Soon
              </span>
            </div>
          </div>
        </div>

        <!-- Right: Phone mockup (React island) -->
        <div class="hero-enter hero-enter-d4 flex justify-center items-center mt-14 lg:mt-0">
          <PhoneMockup client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURES ──────────────────────────────────────────── -->
  <section class="py-28 px-6" style="background: var(--color-bg);">
    <div class="max-w-7xl mx-auto">

      <!-- Section header -->
      <div class="reveal mb-16">
        <h2
          class="font-bold tracking-tight leading-tight mb-5"
          style="font-size: clamp(2rem, 4vw, 3.25rem); color: var(--color-text);"
        >
          Designed around how<br />ears actually learn.
        </h2>
        <p style="font-size: 1.1rem; color: var(--color-text-2); max-width: 48ch; line-height: 1.7;">
          Most ear training apps teach relative pitch — intervals between notes. Absolute Ear trains
          something harder and more valuable: naming notes from sound alone, with no reference pitch.
        </p>
      </div>

      <!-- Bento grid: 2+1 / 1+2 asymmetric -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

        <!-- Wide: Progressive learning -->
        <div
          class="bento-card md:col-span-2 reveal reveal-d1 rounded-2xl p-8 border"
          style="background: var(--color-surface); border-color: var(--color-border);"
        >
          <div
            class="font-mono uppercase tracking-[0.2em] mb-3"
            style="font-size: 10px; color: var(--color-accent);"
          >
            Progressive learning
          </div>
          <h3 class="font-bold tracking-tight mb-3" style="font-size: 1.2rem; color: var(--color-text);">
            Start small. Build mastery.
          </h3>
          <p class="leading-relaxed mb-8" style="font-size: 0.875rem; color: var(--color-text-2); max-width: 44ch;">
            Begin with just C, E, and G — three tonally distinct anchors. Each new note unlocks only
            after you hit 80% accuracy across your last 20 attempts. No shortcuts.
          </p>

          <!-- Unlock path visual -->
          <div class="flex flex-wrap items-center gap-x-2 gap-y-2">
            <!-- Starting group (unlocked) -->
            {['C', 'E', 'G'].map((n) => (
              <span
                class="font-mono font-semibold rounded-lg"
                style="font-size: 11px; padding: 5px 10px; background: var(--color-accent-light); color: var(--color-accent);"
              >
                {n}
              </span>
            ))}

            <div class="h-px w-5" style="background: var(--color-accent);"></div>

            <!-- D, F (unlocked) -->
            {['D', 'F'].map((n, i) => (
              <Fragment>
                <span
                  class="font-mono font-semibold rounded-lg"
                  style="font-size: 11px; padding: 5px 10px; background: var(--color-accent-light); color: var(--color-accent);"
                >
                  {n}
                </span>
                {i === 0 && <div class="h-px w-5" style="background: var(--color-accent);"></div>}
              </Fragment>
            ))}

            <div class="h-px w-5" style="background: var(--color-accent);"></div>

            <!-- A (active) -->
            <span
              class="font-mono font-bold rounded-lg"
              style="font-size: 11px; padding: 5px 10px; background: var(--color-accent); color: var(--color-surface);"
            >
              A
            </span>

            <div class="h-px w-5" style="background: var(--color-border);"></div>

            <!-- Locked notes -->
            {['B', 'C#', 'D#', 'F#', 'G#', 'A#'].map((n, i) => (
              <Fragment>
                {i > 0 && <div class="h-px w-2" style="background: var(--color-border);"></div>}
                <span
                  class="font-mono font-semibold rounded-lg"
                  style="font-size: 11px; padding: 5px 10px; background: var(--color-surface-muted); color: var(--color-text-3);"
                >
                  {n}
                </span>
              </Fragment>
            ))}
          </div>
        </div>

        <!-- Narrow: Smart repetition -->
        <div
          class="bento-card reveal reveal-d2 rounded-2xl p-8 border"
          style="background: var(--color-surface); border-color: var(--color-border);"
        >
          <div
            class="font-mono uppercase tracking-[0.2em] mb-3"
            style="font-size: 10px; color: var(--color-accent);"
          >
            Smart practice
          </div>
          <h3 class="font-bold tracking-tight mb-3" style="font-size: 1.2rem; color: var(--color-text);">
            Weak notes come back more often.
          </h3>
          <p class="leading-relaxed" style="font-size: 0.875rem; color: var(--color-text-2); line-height: 1.7;">
            The algorithm tracks your accuracy per note and weights your practice toward
            the ones you struggle with most — so no note gets left behind.
          </p>

          <!-- Weighted repetition visual: hard notes appear more often -->
          <div class="flex flex-wrap gap-1.5 mt-5" aria-hidden="true">
            {(['F#', 'D#', 'A#', 'F#', 'G#', 'D#', 'C', 'F#', 'A#', 'D#', 'G', 'G#'] as const).map((n) => {
              const isStruggle = ['F#', 'D#', 'A#', 'G#'].includes(n)
              return (
                <span
                  class="font-mono font-semibold rounded-lg"
                  style={`font-size: 10px; padding: ${isStruggle ? '4px 9px' : '3px 7px'}; background: ${isStruggle ? 'var(--color-accent-light)' : 'var(--color-surface-muted)'}; color: ${isStruggle ? 'var(--color-accent)' : 'var(--color-text-3)'};`}
                >
                  {n}
                </span>
              )
            })}
          </div>
        </div>

        <!-- Narrow: Training modes -->
        <div
          class="bento-card reveal reveal-d3 rounded-2xl p-8 border"
          style="background: var(--color-surface); border-color: var(--color-border);"
        >
          <div
            class="font-mono uppercase tracking-[0.2em] mb-3"
            style="font-size: 10px; color: var(--color-accent);"
          >
            Training modes
          </div>
          <h3 class="font-bold tracking-tight mb-3" style="font-size: 1.2rem; color: var(--color-text);">
            Five ways to practice.
          </h3>
          <p class="leading-relaxed mb-6" style="font-size: 0.875rem; color: var(--color-text-2); line-height: 1.7;">
            Single note recognition builds the foundation. Melodic dictation scales from
            2-note sequences up to 5, and interval training progresses from a fixed tonic
            through multiple root notes to fully random roots. Then the app moves into
            harmony: hearing chords by function and recognizing the shape of common
            4-chord loops by degree.
          </p>
          <div class="flex flex-col gap-2.5">
            {FEATURES.map((f) => (
              <div class="flex items-stretch gap-3">
                <div
                  class="flex-shrink-0 rounded-full"
                  style="width: 2px; background: var(--color-accent);"
                ></div>
                <div class="py-0.5">
                  <div class="font-semibold" style="font-size: 13px; color: var(--color-text); margin-bottom: 1px;">{f.label}</div>
                  <div style="font-size: 12px; color: var(--color-text-3);">{f.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Wide: Deep analytics -->
        <div
          class="bento-card md:col-span-2 reveal reveal-d4 rounded-2xl p-8 border"
          style="background: var(--color-surface); border-color: var(--color-border);"
        >
          <div
            class="font-mono uppercase tracking-[0.2em] mb-3"
            style="font-size: 10px; color: var(--color-accent);"
          >
            Analytics
          </div>
          <h3 class="font-bold tracking-tight mb-3" style="font-size: 1.2rem; color: var(--color-text);">
            See exactly where you stand.
          </h3>
          <p class="leading-relaxed mb-8" style="font-size: 0.875rem; color: var(--color-text-2); max-width: 44ch; line-height: 1.7;">
            Per-note accuracy curves, chord and progression tracking, streaks, and mastery signals.
            Know which sounds you confuse most — and watch them tighten over time.
          </p>

          <!-- Per-note accuracy bars -->
          <div class="grid grid-cols-2 gap-x-4 sm:gap-x-8 gap-y-2.5">
            {NOTE_ACCURACY.map((n) => (
              <div class="flex items-center gap-2.5">
                <span
                  class="font-mono flex-shrink-0 text-right"
                  style="font-size: 11px; color: var(--color-text-3); width: 24px;"
                >
                  {n.note}
                </span>
                <div
                  class="flex-1 relative"
                  style="height: 3px; background: var(--color-border); border-radius: 2px;"
                >
                  <div
                    style={`position: absolute; left: 0; top: 0; bottom: 0; width: ${n.pct}%; border-radius: 2px; background: ${n.mastered ? 'var(--color-accent)' : 'var(--color-text-3)'}; opacity: ${n.mastered ? '1' : '0.45'};`}
                  />
                </div>
                <span
                  class="font-mono flex-shrink-0 text-right"
                  style="font-size: 10px; color: var(--color-text-3); width: 28px;"
                >
                  {n.pct}%
                </span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── HARMONY CHAPTERS ─────────────────────────────────── -->
  <section
    class="py-28 px-6"
    style="background: linear-gradient(180deg, var(--color-dark-bg) 0%, #121a24 100%); border-top: 1px solid rgba(47,53,65,0.7);"
  >
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-[0.82fr_1.18fr] gap-6 lg:gap-8 items-start mb-8">
        <div class="reveal">
          <div
            class="font-mono uppercase tracking-[0.22em] mb-4"
            style="font-size: 10px; color: var(--color-dark-accent);"
          >
            New chapters
          </div>
          <h2
            class="font-bold tracking-tight mb-5"
            style="font-size: clamp(2.1rem, 4.5vw, 3.75rem); line-height: 0.95; color: var(--color-dark-text);"
          >
            From pitch<br />into harmony.
          </h2>
          <p style="font-size: 1.05rem; color: var(--color-dark-text-2); line-height: 1.75; max-width: 42ch;">
            Absolute Ear now continues past single notes and intervals into two full harmony chapters:
            <span style="color: var(--color-dark-text);"> Chords</span> and
            <span style="color: var(--color-dark-text);"> Chord Progressions</span>.
            The path stays anchored in C major, so your ear learns function first and labels second.
          </p>
        </div>

        <div
          class="reveal reveal-d1 rounded-[2rem] border p-7 sm:p-8"
          style="background: linear-gradient(145deg, rgba(22,26,33,0.92) 0%, rgba(14,19,27,0.96) 100%); border-color: rgba(56,217,217,0.16); box-shadow: 0 28px 80px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.04);"
        >
          <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-6 items-start">
            <div>
              <div
                class="font-mono uppercase tracking-[0.22em] mb-3"
                style="font-size: 10px; color: var(--color-dark-accent);"
              >
                Anchor point
              </div>
              <p
                class="font-bold tracking-tight mb-3"
                style="font-size: 1.35rem; line-height: 1.08; color: var(--color-dark-text); max-width: 16ch;"
              >
                Hear where every chord lives relative to home.
              </p>
              <p style="font-size: 0.95rem; color: var(--color-dark-text-2); line-height: 1.75; max-width: 34ch;">
                Every harmony lesson starts from the same reference: I establishes home, then the ear learns
                lift, pull, darker color, and full resolution by scale degree.
              </p>
            </div>

            <div
              class="rounded-[1.5rem] border p-4 sm:p-5"
              style="min-width: 220px; background: rgba(9,13,18,0.6); border-color: rgba(56,217,217,0.12);"
            >
              <div class="flex items-center gap-2 mb-3">
                <div class="h-2 w-2 rounded-full" style="background: var(--color-dark-accent);"></div>
                <span class="font-mono" style="font-size: 10px; letter-spacing: 0.18em; color: var(--color-dark-text-3); text-transform: uppercase;">
                  Example loops
                </span>
              </div>
              <div class="flex flex-col gap-2.5">
                {PROGRESSION_PATTERNS.map((pattern) => (
                  <div
                    class="rounded-2xl border p-3"
                    style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.06);"
                  >
                    <div class="font-semibold" style="font-size: 13px; color: var(--color-dark-text); margin-bottom: 4px;">
                      {pattern.name}
                    </div>
                    <div class="font-mono" style="font-size: 11px; color: var(--color-dark-accent); margin-bottom: 3px;">
                      {pattern.degrees}
                    </div>
                    <div style="font-size: 11px; color: var(--color-dark-text-3);">
                      {pattern.vibe}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
        {HARMONY_CHAPTERS.map((chapter, i) => (
          <div
            class={`reveal reveal-d${Math.min(i + 2, 4)} rounded-[2rem] border p-6 sm:p-8`}
            style={`background: linear-gradient(160deg, rgba(20,25,33,0.94) 0%, rgba(11,15,21,0.98) 100%); border-color: rgba(255,255,255,0.08); box-shadow: 0 24px 72px rgba(0,0,0,0.24);`}
          >
            <div class="flex items-start justify-between gap-4 mb-6">
              <div>
