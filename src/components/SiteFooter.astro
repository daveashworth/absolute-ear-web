---
import LogoMark from './LogoMark.astro'

interface Props {
  activePage?: 'support' | 'privacy' | 'terms'
}

const { activePage } = Astro.props
---

<footer
  class="py-10 px-6"
  style="background: var(--color-dark-bg); border-top: 1px solid var(--color-dark-border);"
>
  <div
    class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4"
  >
    <div class="flex items-center gap-3" style="opacity: 0.65;">
      <LogoMark size="sm" />
      <span style="font-size: 14px; color: var(--color-dark-text-3);">Absolute Ear</span>
    </div>

    <nav aria-label="Footer navigation">
      <div class="flex items-center gap-5">
        <a
          href="/support"
          class="footer-link"
          aria-current={activePage === 'support' ? 'page' : undefined}
        >Support</a>
        <a
          href="/privacy"
          class="footer-link"
          aria-current={activePage === 'privacy' ? 'page' : undefined}
        >Privacy Policy</a>
        <a
          href="/terms"
          class="footer-link"
          aria-current={activePage === 'terms' ? 'page' : undefined}
        >Terms of Service</a>
      </div>
    </nav>
  </div>
</footer>

<style>
  .footer-link {
    font-size: 13px;
    color: var(--color-dark-text-3);
    font-family: var(--font-mono);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover,
  .footer-link[aria-current="page"] {
    color: var(--color-dark-text-2);
  }

  .footer-link:focus-visible {
    outline: 2px solid var(--color-dark-accent);
    outline-offset: 3px;
    border-radius: 3px;
  }
</style>
