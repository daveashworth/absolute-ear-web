---
import LogoMark from './LogoMark.astro'

interface Props {
  pageTitle: string
}

const { pageTitle } = Astro.props
---

<nav
  class="sticky top-0 z-50 px-6 h-16 flex items-center justify-between"
  style="background: var(--color-dark-bg); border-bottom: 1px solid var(--color-dark-border);"
>
  <a href="/" class="flex items-center gap-3" style="text-decoration: none;">
    <LogoMark />
    <span style="color: var(--color-dark-text); font-weight: 600; letter-spacing: -0.02em;">
      Absolute Ear
    </span>
  </a>
  <span style="font-size: 13px; color: var(--color-dark-text-3);">{pageTitle}</span>
</nav>
