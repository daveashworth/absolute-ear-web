---
import Layout from '../layouts/Layout.astro'
import PhoneMockup from '../components/PhoneMockup.tsx'

// SVG icons inlined for zero-dependency icons
const AppleSVG = `<svg width="18" height="22" viewBox="0 0 24 29" fill="currentColor" aria-hidden="true"><path d="M20.92 22.27c-.97 1.45-1.99 2.87-3.57 2.9-1.57.04-2.07-.93-3.85-.93-1.79 0-2.34.9-3.83.96-1.53.06-2.69-1.54-3.67-2.97C3.35 19.41 1.77 13.73 3.9 9.84c1.02-1.78 2.84-2.9 4.82-2.94 1.5-.02 2.92 1.01 3.85 1.01.91 0 2.64-1.25 4.45-1.07.76.04 2.88.31 4.25 2.32-.1.07-2.54 1.5-2.51 4.46.04 3.54 3.1 4.71 3.13 4.73-.03.07-.49 1.68-1.62 3.3zm-4.33-18.9c.85-.97 2.27-1.7 3.44-1.74.15 1.37-.4 2.75-1.22 3.73-.8 1-2.14 1.77-3.45 1.66-.18-1.34.48-2.75 1.23-3.65z"/></svg>`

const PlaySVG = `<svg width="18" height="20" viewBox="0 0 24 27" fill="currentColor" aria-hidden="true"><path d="M2.13 26.5c.38.21.84.23 1.26.02L18.98 18.1l-3.47-3.47L2.13 26.5zm-1.75-22.4v22.05c0 .52.3.97.71 1.19V2.91c-.41.22-.71.67-.71 1.19zM16.89 11.56l2.07-1.16.06-.04L5.63.31 3.39.02l13.5 11.54zM20.47 9.5l-1.51 2.06-6.23 5.85 6.23 5.85 1.51-.84c.96-.54.96-1.5 0-2.04L20.47 9.5z"/></svg>`

const CHROMATIC_NOTES = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B']

const STEPS = [
  {
    num: '01',
    title: 'Listen',
    body: 'A note plays from a real piano sample. Replay it as many times as you need. There is no time pressure.',
  },
  {
    num: '02',
    title: 'Identify',
    body: 'Tap the note name you heard. Instant visual and haptic feedback confirms your answer.',
  },
  {
    num: '03',
    title: 'Unlock',
    body: 'Hit 80% accuracy across 20 attempts to unlock the next note. Genuine mastery — not just repetition.',
  },
]

const FEATURES = [
  { label: 'Note recognition', desc: 'Hear a note. Name it.' },
  { label: 'Melodic dictation', desc: '2-note sequences' },
  { label: 'Interval training', desc: 'Relative pitch distance' },
]

const STATS = [
  { val: '84%', label: 'Overall accuracy' },
  { val: '47', label: 'Current streak' },
  { val: '7/12', label: 'Notes mastered' },
]
---

<Layout>
  <!-- ── NAV ──────────────────────────────────────────────── -->
  <nav
    class="fixed top-0 left-0 right-0 z-50"
    style="background: rgba(15,17,21,0.9); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(47,53,65,0.5);"
  >
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="/icon.png" alt="Absolute Ear" class="w-8 h-8 rounded-xl" />
        <span style="color:#f8fafc; font-weight:600; letter-spacing:-0.02em;">Absolute Ear</span>
      </div>
      <div class="flex items-center gap-2.5">
        <div
          class="w-2 h-2 rounded-full"
          style="background:#38d9d9; animation: pulse-dot 2s ease-in-out infinite;"
        ></div>
        <span style="font-size:13px; color:#8d96a5; font-family: var(--font-mono);">Coming Soon</span>
      </div>
    </div>
  </nav>

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section
    class="min-h-[100dvh] flex items-center pt-16"
    style="background: #0f1115;"
  >
    <div class="max-w-7xl mx-auto px-6 py-20 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] xl:grid-cols-[1fr_340px] gap-12 xl:gap-20 items-center">

        <!-- Left: Content -->
        <div>
          <!-- Tag line -->
          <div class="flex items-center gap-3 mb-10">
            <div class="h-px w-8" style="background:#38d9d9;"></div>
            <span style="font-size:11px; font-family:var(--font-mono); color:#38d9d9; text-transform:uppercase; letter-spacing:0.2em;">
              iOS · Android · Coming Soon
            </span>
          </div>

          <!-- Headline -->
          <h1
            class="font-bold leading-[1.04] tracking-tight mb-7"
            style="font-size: clamp(2.8rem, 6vw, 5.5rem); color:#f8fafc;"
          >
            Train your ears<br />
            to hear every<br />
            <span style="color:#38d9d9;">note.</span>
          </h1>

          <!-- Body -->
          <p
            class="leading-relaxed mb-10"
            style="font-size:1.125rem; color:#c3c9d4; max-width:46ch;"
          >
            Absolute Ear builds reliable pitch recognition through progressive, focused practice —
            starting from three notes and expanding to all twelve chromatic tones.
          </p>

          <!-- Store buttons -->
          <div class="flex flex-wrap gap-4">
            <!-- App Store -->
            <div class="relative">
              <a
                href="#download"
                class="flex items-center gap-3 rounded-xl font-semibold transition-all duration-200 hover:opacity-90 active:scale-[0.97]"
                style="padding: 12px 22px; background:#f8fafc; color:#0f1115;"
                aria-label="Download on the App Store (coming soon)"
              >
                <Fragment set:html={AppleSVG} />
                <div>
                  <div style="font-size:10px; font-weight:500; opacity:0.6; line-height:1; margin-bottom:2px;">
                    Download on the
                  </div>
                  <div style="font-size:15px; font-weight:700; line-height:1;">App Store</div>
                </div>
              </a>
              <span
                class="absolute -top-2 -right-2 font-mono font-bold rounded-full"
                style="font-size:9px; background:#38d9d9; color:#0f1115; padding:2px 7px;"
              >
                Soon
              </span>
            </div>

            <!-- Google Play -->
            <div class="relative">
              <a
                href="#download"
                class="flex items-center gap-3 rounded-xl font-semibold transition-all duration-200 hover:border-dark-text-3 active:scale-[0.97]"
                style="padding: 12px 22px; border: 1px solid #2f3541; color:#f8fafc; background:transparent;"
                aria-label="Get it on Google Play (coming soon)"
              >
                <Fragment set:html={PlaySVG} />
                <div>
                  <div style="font-size:10px; font-weight:500; opacity:0.6; line-height:1; margin-bottom:2px;">
                    Get it on
                  </div>
                  <div style="font-size:15px; font-weight:700; line-height:1;">Google Play</div>
                </div>
              </a>
              <span
                class="absolute -top-2 -right-2 font-mono font-bold rounded-full"
                style="font-size:9px; background:#38d9d9; color:#0f1115; padding:2px 7px;"
              >
                Soon
              </span>
            </div>
          </div>
        </div>

        <!-- Right: Phone mockup (React island) -->
        <div class="hidden lg:flex justify-center items-center">
          <PhoneMockup client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURES ──────────────────────────────────────────── -->
  <section class="py-28 px-6" style="background:#f7f7f5;">
    <div class="max-w-7xl mx-auto">

      <!-- Section header -->
      <div class="reveal mb-16">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-1 h-5 rounded-full" style="background:#0e9aa7;"></div>
          <span style="font-size:11px; font-family:var(--font-mono); color:#0e9aa7; text-transform:uppercase; letter-spacing:0.2em;">
            Why it works
          </span>
        </div>
        <h2
          class="font-bold tracking-tight leading-tight mb-5"
          style="font-size:clamp(2rem, 4vw, 3.25rem); color:#101216;"
        >
          Designed around how<br />ears actually learn.
        </h2>
        <p style="font-size:1.1rem; color:#4b5563; max-width:48ch; line-height:1.7;">
          Most ear training apps teach relative pitch — intervals between notes. Absolute Ear trains
          something harder and more valuable: naming notes from sound alone, with no reference pitch.
        </p>
      </div>

      <!-- Bento grid: 2+1 / 1+2 asymmetric -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

        <!-- Wide: Progressive learning -->
        <div
          class="md:col-span-2 reveal reveal-d1 rounded-2xl p-8 border"
          style="background:#ffffff; border-color:#d6dadd;"
        >
          <div
            class="font-mono uppercase tracking-[0.2em] mb-3"
            style="font-size:10px; color:#0e9aa7;"
          >
            Progressive learning
          </div>
          <h3 class="font-bold tracking-tight mb-3" style="font-size:1.2rem; color:#101216;">
            Start small. Build mastery.
          </h3>
          <p class="leading-relaxed mb-8" style="font-size:0.875rem; color:#4b5563; max-width:44ch;">
            Begin with just C, E, and G — three tonally distinct anchors. Each new note unlocks only
            after you hit 80% accuracy across your last 20 attempts. No shortcuts.
          </p>

          <!-- Unlock path visual -->
          <div class="flex flex-wrap items-center gap-x-2 gap-y-2">
            <!-- Starting group (unlocked) -->
            {['C', 'E', 'G'].map((n) => (
              <span
                class="font-mono font-semibold rounded-lg"
                style={`font-size:11px; padding:5px 10px; background:#e3f5f5; color:#0e9aa7;`}
              >
                {n}
              </span>
            ))}

            <div class="h-px w-5" style="background:#0e9aa7;"></div>

            <!-- D, F (unlocked) -->
            {['D', 'F'].map((n, i) => (
              <Fragment>
                <span
                  class="font-mono font-semibold rounded-lg"
                  style="font-size:11px; padding:5px 10px; background:#e3f5f5; color:#0e9aa7;"
                >
                  {n}
                </span>
                {i === 0 && <div class="h-px w-5" style="background:#0e9aa7;"></div>}
              </Fragment>
            ))}

            <div class="h-px w-5" style="background:#0e9aa7;"></div>

            <!-- A (active) -->
            <span
              class="font-mono font-bold rounded-lg"
              style="font-size:11px; padding:5px 10px; background:#0e9aa7; color:#ffffff;"
            >
              A
            </span>

            <div class="h-px w-5" style="background:#d6dadd;"></div>

            <!-- Locked notes -->
            {['B', 'C#', 'D#', 'F#', 'G#', 'A#'].map((n, i) => (
              <Fragment>
                {i > 0 && <div class="h-px w-2" style="background:#d6dadd;"></div>}
                <span
                  class="font-mono font-semibold rounded-lg"
                  style="font-size:11px; padding:5px 10px; background:#eef0f2; color:#7b8794;"
                >
                  {n}
                </span>
              </Fragment>
            ))}
          </div>
        </div>

        <!-- Narrow: Smart repetition -->
        <div
          class="reveal reveal-d2 rounded-2xl p-8 border"
          style="background:#ffffff; border-color:#d6dadd;"
        >
          <div
            class="font-mono uppercase tracking-[0.2em] mb-3"
            style="font-size:10px; color:#0e9aa7;"
          >
            Smart practice
          </div>
          <h3 class="font-bold tracking-tight mb-3" style="font-size:1.2rem; color:#101216;">
            Weak notes come back more often.
          </h3>
          <p class="leading-relaxed" style="font-size:0.875rem; color:#4b5563; line-height:1.7;">
            The algorithm tracks your accuracy per note and weights your practice toward
            the ones you struggle with most — so no note gets left behind.
          </p>
        </div>

        <!-- Narrow: Training modes -->
        <div
          class="reveal reveal-d3 rounded-2xl p-8 border"
          style="background:#ffffff; border-color:#d6dadd;"
        >
          <div
            class="font-mono uppercase tracking-[0.2em] mb-3"
            style="font-size:10px; color:#0e9aa7;"
          >
            Training modes
          </div>
          <h3 class="font-bold tracking-tight mb-3" style="font-size:1.2rem; color:#101216;">
            Three ways to practice.
          </h3>
          <p class="leading-relaxed mb-6" style="font-size:0.875rem; color:#4b5563; line-height:1.7;">
            Single note recognition builds the foundation. Melodic dictation and interval training
            push your ears further.
          </p>
          <div class="flex flex-col gap-3">
            {FEATURES.map((f) => (
              <div class="flex items-start gap-3">
                <div
                  class="rounded-full flex-shrink-0 mt-1.5"
                  style="width:6px; height:6px; background:#0e9aa7;"
                ></div>
                <div>
                  <div class="font-semibold" style="font-size:13px; color:#101216;">{f.label}</div>
                  <div style="font-size:12px; color:#7b8794;">{f.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Wide: Deep analytics -->
        <div
          class="md:col-span-2 reveal reveal-d4 rounded-2xl p-8 border"
          style="background:#ffffff; border-color:#d6dadd;"
        >
          <div
            class="font-mono uppercase tracking-[0.2em] mb-3"
            style="font-size:10px; color:#0e9aa7;"
          >
            Analytics
          </div>
          <h3 class="font-bold tracking-tight mb-3" style="font-size:1.2rem; color:#101216;">
            See exactly where you stand.
          </h3>
          <p class="leading-relaxed mb-8" style="font-size:0.875rem; color:#4b5563; max-width:44ch; line-height:1.7;">
            Per-note accuracy curves, confusion matrices, streaks, and mastery tracking.
            Know which notes you mix up — and watch them improve over time.
          </p>

          <!-- Mini stats (using organic-looking numbers) -->
          <div class="grid grid-cols-3 gap-6">
            {STATS.map((s) => (
              <div>
                <div
                  class="font-bold font-mono mb-1"
                  style="font-size:2rem; color:#101216; letter-spacing:-0.02em;"
                >
                  {s.val}
                </div>
                <div
                  class="uppercase tracking-wider"
                  style="font-size:10px; color:#7b8794; font-family:var(--font-mono);"
                >
                  {s.label}
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ──────────────────────────────────────── -->
  <section class="py-28 px-6" style="background:#eef0f2;">
    <div class="max-w-7xl mx-auto">

      <div class="reveal mb-16">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-1 h-5 rounded-full" style="background:#0e9aa7;"></div>
          <span
            class="font-mono uppercase"
            style="font-size:11px; color:#0e9aa7; letter-spacing:0.2em;"
          >
            The process
          </span>
        </div>
        <h2
          class="font-bold tracking-tight"
          style="font-size:clamp(2rem, 4vw, 3.25rem); color:#101216;"
        >
          How it works.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16">
        {STEPS.map((step, i) => (
          <div class={`reveal reveal-d${i + 1}`}>
            <div
              class="font-mono font-bold mb-5"
              style="font-size:3.5rem; color:#0e9aa7; opacity:0.18; line-height:1; letter-spacing:-0.04em;"
            >
              {step.num}
            </div>
            <h3 class="font-bold mb-3" style="font-size:1.25rem; color:#101216;">{step.title}</h3>
            <p style="color:#4b5563; line-height:1.7;">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── LEARNING PATH ─────────────────────────────────────── -->
  <section class="py-28 px-6" style="background:#0f1115;">
    <div class="max-w-7xl mx-auto">

      <div class="reveal mb-14">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-8" style="background:#38d9d9;"></div>
          <span
            class="font-mono uppercase"
            style="font-size:11px; color:#38d9d9; letter-spacing:0.2em;"
          >
            The curriculum
          </span>
        </div>
        <h2
          class="font-bold tracking-tight mb-5"
          style="font-size:clamp(2rem, 4vw, 3.25rem); color:#f8fafc;"
        >
          From three notes<br />to twelve.
        </h2>
        <p style="font-size:1.1rem; color:#c3c9d4; max-width:46ch; line-height:1.7;">
          The unlock order is deliberate — start with the most tonally distinct notes,
          then introduce each new pitch as your ear becomes more refined.
        </p>
      </div>

      <!-- Chromatic note grid -->
      <div class="reveal overflow-x-auto pb-2">
        <div class="flex items-start gap-4 min-w-max">

          <!-- Starting group -->
          <div class="flex flex-col items-center gap-2.5">
            <div class="flex gap-2">
              {['C', 'E', 'G'].map((n) => (
                <div
                  class="font-mono font-bold flex items-center justify-center rounded-xl"
                  style="width:44px; height:44px; font-size:13px; background: rgba(56,217,217,0.12); border: 1.5px solid #38d9d9; color:#38d9d9;"
                >
                  {n}
                </div>
              ))}
            </div>
            <span class="font-mono" style="font-size:10px; color:#8d96a5;">Start</span>
          </div>

          <!-- White key unlocks -->
          {['D', 'F', 'A', 'B'].map((n, i) => (
            <Fragment>
              <div class="flex items-center mt-2.5">
                <svg width="20" height="2" aria-hidden="true">
                  <line x1="0" y1="1" x2="20" y2="1" stroke="#2f3541" stroke-width="1.5"/>
                </svg>
              </div>
              <div class="flex flex-col items-center gap-2.5">
                <div
                  class="font-mono font-bold flex items-center justify-center rounded-xl"
                  style="width:44px; height:44px; font-size:13px; background:#161a21; border:1px solid #2f3541; color:#c3c9d4;"
                >
                  {n}
                </div>
                <span class="font-mono" style="font-size:10px; color:#8d96a5;">#{i + 1}</span>
              </div>
            </Fragment>
          ))}

          <!-- Divider to chromatics -->
          <div class="flex items-center mt-2.5">
            <svg width="20" height="2" aria-hidden="true">
              <line x1="0" y1="1" x2="20" y2="1" stroke="#2f3541" stroke-width="1.5"/>
            </svg>
          </div>

          <!-- Chromatic group -->
          <div class="flex flex-col items-center gap-2.5">
            <div class="flex gap-2">
              {['C#', 'D#', 'F#', 'G#', 'A#'].map((n) => (
                <div
                  class="font-mono font-bold flex items-center justify-center rounded-xl"
                  style="width:44px; height:44px; font-size:11px; background:#1d222b; border:1px solid #2f3541; color:#8d96a5;"
                >
                  {n}
                </div>
              ))}
            </div>
            <span class="font-mono" style="font-size:10px; color:#8d96a5;">Chromatic</span>
          </div>

        </div>
      </div>

      <!-- Unlock condition callout -->
      <div
        class="reveal mt-12 inline-flex items-center gap-3 rounded-xl px-5 py-3"
        style="background:#1d222b; border:1px solid #2f3541;"
      >
        <div class="rounded-full" style="width:7px; height:7px; background:#38d9d9; flex-shrink:0;"></div>
        <span style="font-size:13px; color:#c3c9d4;">
          Each note unlocks at <span style="color:#38d9d9; font-weight:700;">80% accuracy</span> across your last 20 attempts
        </span>
      </div>
    </div>
  </section>

  <!-- ── DOWNLOAD CTA ───────────────────────────────────────── -->
  <section id="download" class="py-28 px-6" style="background:#0f1115; border-top:1px solid #2f3541;">
    <div class="max-w-7xl mx-auto">
      <div class="reveal" style="max-width: 560px;">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px w-8" style="background:#38d9d9;"></div>
          <span class="font-mono uppercase" style="font-size:11px; color:#38d9d9; letter-spacing:0.2em;">
            Download
          </span>
        </div>
        <h2
          class="font-bold tracking-tight mb-5"
          style="font-size:clamp(2rem, 4vw, 3.25rem); color:#f8fafc;"
        >
          Available soon on<br />iOS and Android.
        </h2>
        <p class="leading-relaxed mb-10" style="font-size:1.1rem; color:#c3c9d4; line-height:1.7;">
          We're putting the finishing touches on Absolute Ear. These links will be live when
          the app launches in the App Store and Google Play.
        </p>

        <div class="flex flex-wrap gap-4">
          <!-- App Store -->
          <div class="relative">
            <a
              href="#download"
              class="flex items-center gap-3 rounded-xl font-semibold transition-all duration-200 hover:opacity-90 active:scale-[0.97]"
              style="padding:12px 22px; background:#f8fafc; color:#0f1115;"
              aria-label="Download on the App Store (coming soon)"
            >
              <Fragment set:html={AppleSVG} />
              <div>
                <div style="font-size:10px; font-weight:500; opacity:0.6; line-height:1; margin-bottom:2px;">Download on the</div>
                <div style="font-size:15px; font-weight:700; line-height:1;">App Store</div>
              </div>
            </a>
            <span
              class="absolute -top-2 -right-2 font-mono font-bold rounded-full"
              style="font-size:9px; background:#38d9d9; color:#0f1115; padding:2px 7px;"
            >
              Soon
            </span>
          </div>

          <!-- Google Play -->
          <div class="relative">
            <a
              href="#download"
              class="flex items-center gap-3 rounded-xl font-semibold transition-all duration-200 active:scale-[0.97]"
              style="padding:12px 22px; border:1px solid #2f3541; color:#f8fafc; background:transparent;"
              aria-label="Get it on Google Play (coming soon)"
            >
              <Fragment set:html={PlaySVG} />
              <div>
                <div style="font-size:10px; font-weight:500; opacity:0.6; line-height:1; margin-bottom:2px;">Get it on</div>
                <div style="font-size:15px; font-weight:700; line-height:1;">Google Play</div>
              </div>
            </a>
            <span
              class="absolute -top-2 -right-2 font-mono font-bold rounded-full"
              style="font-size:9px; background:#38d9d9; color:#0f1115; padding:2px 7px;"
            >
              Soon
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ─────────────────────────────────────────────── -->
  <footer class="py-10 px-6" style="background:#0f1115; border-top:1px solid #2f3541;">
    <div
      class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4"
    >
      <div class="flex items-center gap-3">
        <img src="/icon.png" alt="Absolute Ear" class="w-6 h-6 rounded-lg" style="opacity:0.6;" />
        <span style="font-size:14px; color:#8d96a5;">Absolute Ear</span>
      </div>
